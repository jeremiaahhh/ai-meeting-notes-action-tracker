# Database
DATABASE_URL=postgresql+psycopg2://meetings:meetings@localhost:5432/meeting_notes

# AI providers — leave keys empty to force mock mode
USE_MOCK_AI=true
AI_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Server
CORS_ORIGINS=http://localhost:3000
LOG_LEVEL=INFO
